APP_ENV=development
HTTP_PORT=8080
JWT_SECRET=change-me
INTERNAL_TOKEN=change-me-too
ALLOW_INSECURE_DEV_AUTH=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_MAX_AGE_SECONDS=86400

POSTGRES_DB=reqst
POSTGRES_USER=reqst
POSTGRES_PASSWORD=reqst
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://reqst:reqst@postgres:5432/reqst?sslmode=disable

WATCHER_POLL_INTERVAL=20s
TRONGRID_BASE_URL=https://api.trongrid.io
TRONGRID_API_KEY=
TONCENTER_BASE_URL=https://toncenter.com/api/v2
TONCENTER_API_KEY=
# Optional manual override for TON/USD conversion.
# Leave empty to auto-fetch from CoinGecko inside the API.
TON_USD_RATE=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://base.llamarpc.com
ARBITRUM_RPC_URL=https://arbitrum.llamarpc.com
BSC_RPC_URL=https://bsc.llamarpc.com

PUBLIC_APP_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=reqst
# Leave empty when frontend proxies /api to backend on the same domain.
VITE_API_BASE_URL=
