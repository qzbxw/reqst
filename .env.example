APP_ENV=development
HTTP_PORT=8080
JWT_SECRET=change-me
INTERNAL_TOKEN=change-me-too
ALLOW_INSECURE_DEV_AUTH=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_MAX_AGE_SECONDS=86400

POSTGRES_DB=reqst
POSTGRES_USER=reqst
POSTGRES_PASSWORD=reqst
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://reqst:reqst@postgres:5432/reqst?sslmode=disable

WATCHER_POLL_INTERVAL=20s
TRONGRID_BASE_URL=https://api.trongrid.io
TRONGRID_API_KEY=
TONCENTER_BASE_URL=https://toncenter.com/api/v2
TONCENTER_API_KEY=
# Optional manual override for TON/USD conversion.
# Leave empty to auto-fetch from CoinGecko inside the API.
TON_USD_RATE=

PUBLIC_APP_URL=http://localhost:5173
# Leave empty when frontend proxies /api to backend on the same domain.
VITE_API_BASE_URL=
